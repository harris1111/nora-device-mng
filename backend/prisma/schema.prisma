generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  LOCKED
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdById  String?    @map("created_by")
  createdBy    User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]     @relation("UserCreatedBy")
  updatedById  String?    @map("updated_by")
  updatedBy    User?      @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  updatedUsers User[]     @relation("UserUpdatedBy")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  devicesCreated              Device[]              @relation("DeviceCreatedBy")
  devicesUpdated              Device[]              @relation("DeviceUpdatedBy")
  locationsCreated            Location[]            @relation("LocationCreatedBy")
  locationsUpdated            Location[]            @relation("LocationUpdatedBy")
  areasCreated                Area[]                @relation("AreaCreatedBy")
  areasUpdated                Area[]                @relation("AreaUpdatedBy")
  maintenanceRecordsCreated   MaintenanceRecord[]   @relation("MaintenanceCreatedBy")
  maintenanceRecordsUpdated   MaintenanceRecord[]   @relation("MaintenanceUpdatedBy")
  scheduledMaintenanceCreated ScheduledMaintenance[] @relation("ScheduledMaintenanceCreatedBy")
  scheduledMaintenanceUpdated ScheduledMaintenance[] @relation("ScheduledMaintenanceUpdatedBy")
  inventoryRecordsCreated     InventoryRecord[]     @relation("InventoryCreatedBy")
  inventoryRecordsUpdated     InventoryRecord[]     @relation("InventoryUpdatedBy")
  scheduledInventoryCreated   ScheduledInventory[]  @relation("ScheduledInventoryCreatedBy")
  scheduledInventoryUpdated   ScheduledInventory[]  @relation("ScheduledInventoryUpdatedBy")
  notifications               Notification[]
  transferRecordsCreated      TransferRecord[]      @relation("TransferCreatedBy")
  transferRecordsUpdated      TransferRecord[]      @relation("TransferUpdatedBy")
  attachmentsCreated          Attachment[]          @relation("AttachmentCreatedBy")
  attachmentsUpdated          Attachment[]          @relation("AttachmentUpdatedBy")
  maintAttachmentsCreated     MaintenanceAttachment[] @relation("MaintAttachCreatedBy")
  maintAttachmentsUpdated     MaintenanceAttachment[] @relation("MaintAttachUpdatedBy")
  inventoryAttachmentsCreated InventoryAttachment[] @relation("InventoryAttachCreatedBy")
  inventoryAttachmentsUpdated InventoryAttachment[] @relation("InventoryAttachUpdatedBy")
  transferAttachmentsCreated  TransferAttachment[]  @relation("TransferAttachCreatedBy")
  transferAttachmentsUpdated  TransferAttachment[]  @relation("TransferAttachUpdatedBy")
  auditLogs                   AuditLog[]
  assignedLocations           UserLocation[]

  @@map("users")
}

model Permission {
  id        String   @id @default(uuid())
  role      UserRole
  module    String
  canView   Boolean  @default(false) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canUpdate Boolean  @default(false) @map("can_update")
  canDelete Boolean  @default(false) @map("can_delete")
  canExport Boolean  @default(false) @map("can_export")

  @@unique([role, module])
  @@map("permissions")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?    @db.JsonB
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Location {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")
  createdBy   User?    @relation("LocationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("LocationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  devices     Device[]
  assignedUsers UserLocation[]

  @@map("locations")
}

model Area {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")
  createdBy   User?    @relation("AreaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("AreaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  devices     Device[]

  @@map("areas")
}

model UserLocation {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, locationId])
  @@map("user_locations")
}

model Device {
  id           String   @id @default(uuid())
  storeId      String   @map("store_id")
  name         String
  locationId   String?  @map("location_id")
  location     Location? @relation(fields: [locationId], references: [id])
  areaId       String?  @map("area_id")
  area         Area?    @relation(fields: [areaId], references: [id])
  managedBy    String   @default("") @map("managed_by")
  ownedBy      String   @default("") @map("owned_by")
  serialNumber String   @default("") @map("serial_number")
  model        String   @default("")
  manufacturer String   @default("")
  description  String   @default("")
  qrcode       Bytes?
  type         String   @default("tai_san")
  status       String   @default("active")
  disposalDate DateTime? @map("disposal_date")
  lossDate     DateTime? @map("loss_date")
  transferTo   String?  @map("transfer_to")
  transferDate DateTime? @map("transfer_date")
  warrantyPeriod String? @map("warranty_period")
  maintenanceStatus String @default("in_use") @map("maintenance_status")
  inventoryStatus String @default("in_use") @map("inventory_status")
  createdAt    DateTime @default(now()) @map("created_at")
  createdById  String?  @map("created_by")
  createdBy    User?    @relation("DeviceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?  @map("updated_by")
  updatedBy    User?    @relation("DeviceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  attachments        Attachment[]
  maintenanceRecords MaintenanceRecord[]
  scheduledMaintenance ScheduledMaintenance?
  inventoryRecords   InventoryRecord[]
  scheduledInventory ScheduledInventory?
  transferRecord     TransferRecord?

  @@map("devices")
}

model TransferRecord {
  id           String   @id @default(uuid())
  deviceId     String   @unique @map("device_id")
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ownedBy      String   @default("") @map("owned_by")
  transferTo   String?  @map("transfer_to")
  transferDate DateTime? @map("transfer_date")
  createdAt    DateTime @default(now()) @map("created_at")
  createdById  String?  @map("created_by")
  createdBy    User?    @relation("TransferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?  @map("updated_by")
  updatedBy    User?    @relation("TransferUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  attachments  TransferAttachment[]

  @@map("transfer_records")
}

model Attachment {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  fileKey     String   @map("file_key")
  fileName    String   @map("file_name")
  fileType    String   @map("file_type")
  fileSize    Int      @map("file_size")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")
  createdBy   User?    @relation("AttachmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("AttachmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("attachments")
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  date        DateTime
  description String
  technician  String   @default("")
  status      String   @default("pending")
  recordType  String   @default("repair") @map("record_type")  // 'maintenance' | 'repair'
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")
  createdBy   User?    @relation("MaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("MaintenanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  attachments MaintenanceAttachment[]

  @@map("maintenance_records")
}

model TransferAttachment {
  id          String         @id @default(uuid())
  transferId  String         @map("transfer_id")
  transfer    TransferRecord @relation(fields: [transferId], references: [id], onDelete: Cascade)
  fileKey     String         @map("file_key")
  fileName    String         @map("file_name")
  fileType    String         @map("file_type")
  fileSize    Int            @map("file_size")
  createdAt   DateTime       @default(now()) @map("created_at")
  createdById String?        @map("created_by")
  createdBy   User?          @relation("TransferAttachCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?        @map("updated_by")
  updatedBy   User?          @relation("TransferAttachUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("transfer_attachments")
}

model MaintenanceAttachment {
  id              String            @id @default(uuid())
  maintenanceId   String            @map("maintenance_id")
  maintenance     MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  fileKey         String            @map("file_key")
  fileName        String            @map("file_name")
  fileType        String            @map("file_type")
  fileSize        Int               @map("file_size")
  createdAt       DateTime          @default(now()) @map("created_at")
  createdById     String?           @map("created_by")
  createdBy       User?             @relation("MaintAttachCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?           @map("updated_by")
  updatedBy       User?             @relation("MaintAttachUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("maintenance_attachments")
}

// Per-device maintenance schedule. Drives reminder notifications and the
// maintenance_status transitions on the parent Device.
model ScheduledMaintenance {
  id               String   @id @default(uuid())
  deviceId         String   @unique @map("device_id")
  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  intervalDays     Int      @map("interval_days")            // recurrence period in days
  notifyDaysBefore Int      @default(7) @map("notify_days_before")
  nextDueAt        DateTime @map("next_due_at")
  lastMaintenanceAt DateTime? @map("last_maintenance_at")    // anchor date used to compute nextDueAt; null => fall back to device.createdAt
  lastNotifiedAt   DateTime? @map("last_notified_at")        // dedupe — null => not yet notified for current cycle
  createdAt        DateTime @default(now()) @map("created_at")
  createdById      String?  @map("created_by")
  createdBy        User?    @relation("ScheduledMaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?  @map("updated_by")
  updatedBy        User?    @relation("ScheduledMaintenanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("scheduled_maintenances")
}

// In-app notifications (delivered via SSE + REST fetch). Per-user; null userId = broadcast.
model Notification {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String                                              // e.g. 'maintenance_due'
  title      String
  message    String
  link       String?                                             // route to navigate to on click
  sourceType String?  @map("source_type")                        // dedupe key prefix, e.g. 'device'
  sourceId   String?  @map("source_id")                          // dedupe key id
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([sourceType, sourceId])
  @@map("notifications")
}

model InventoryRecord {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  date        DateTime
  description String
  technician  String   @default("")
  status      String   @default("pending")                              // 'pending' | 'completed'
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")
  createdBy   User?    @relation("InventoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by")
  updatedBy   User?    @relation("InventoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  attachments InventoryAttachment[]

  @@map("inventory_records")
}

model InventoryAttachment {
  id              String          @id @default(uuid())
  inventoryId     String          @map("inventory_id")
  inventory       InventoryRecord @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  fileKey         String          @map("file_key")
  fileName        String          @map("file_name")
  fileType        String          @map("file_type")
  fileSize        Int             @map("file_size")
  createdAt       DateTime        @default(now()) @map("created_at")
  createdById     String?         @map("created_by")
  createdBy       User?           @relation("InventoryAttachCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?         @map("updated_by")
  updatedBy       User?           @relation("InventoryAttachUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("inventory_attachments")
}

// Per-device inventory schedule. Drives reminder notifications and the
// inventory_status transitions on the parent Device. Mirrors ScheduledMaintenance.
model ScheduledInventory {
  id               String   @id @default(uuid())
  deviceId         String   @unique @map("device_id")
  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  intervalDays     Int      @map("interval_days")
  notifyDaysBefore Int      @default(7) @map("notify_days_before")
  nextDueAt        DateTime @map("next_due_at")
  lastInventoryAt  DateTime? @map("last_inventory_at")
  lastNotifiedAt   DateTime? @map("last_notified_at")
  createdAt        DateTime @default(now()) @map("created_at")
  createdById      String?  @map("created_by")
  createdBy        User?    @relation("ScheduledInventoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?  @map("updated_by")
  updatedBy        User?    @relation("ScheduledInventoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("scheduled_inventories")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
